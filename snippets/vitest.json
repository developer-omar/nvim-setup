{
  "Describe - Vitest": {
    "prefix": "v-describe",
    "body": ["describe('$1', () => {", "\t$2", "});"]
  },
  "Individual Test - Vitest": {
    "prefix": "v-it",
    "body": ["it('$1', () => {", "\t$2", "});"]
  },
  "Angular Component Test - Vitest": {
    "prefix": "a-component-test",
    "body": [
      "import { ComponentFixture, TestBed } from '@angular/core/testing';",
      "import ${1:Component} from './$2';",
      "",
      "describe('${1:Component}', () => {",
      "  let component: ${1:Component};",
      "  let fixture: ComponentFixture<${1:Component}>;",
      "",
      "  beforeEach(() => {",
      "    TestBed.configureTestingModule({",
      "      imports: [${1:Component}],",
      "    });",
      "    fixture = TestBed.createComponent(${1:Component});",
      "    component = fixture.componentInstance;",
      "    fixture.detectChanges(); // important",
      "  });",
      "",
      "  it('Should create', () => {",
      "    expect(component).toBeTruthy();",
      "  });$3",
      "});"
    ]
  }
}
